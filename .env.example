# ── Required ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-
OPTIMUS_API_KEY=your-32-char-minimum-key-here

# ── LLM ───────────────────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
CLAUDE_MODEL=claude-sonnet-4-6
MISTRAL_MODEL=mistral:7b-instruct-v0.2-q4_K_M
EMBED_MODEL=nomic-embed-text

# ── Budget ────────────────────────────────────────────────
SESSION_TOKEN_BUDGET=500000
SUMMARISER_THRESHOLD=60000

# ── Execution ─────────────────────────────────────────────
KALI_HOST=kali
KALI_PORT=22
KALI_USER=kali
KALI_PASSWORD=kali

# ── Intelligence ──────────────────────────────────────────
TOR_SOCKS_HOST=tor
TOR_SOCKS_PORT=9050
INTEL_TTL_SECONDS=3600

# ── Storage ───────────────────────────────────────────────
MEMORY_DB_PATH=/app/data/optimus_memory.db
INTEL_CACHE_PATH=/app/data/intel_cache
REPORTS_PATH=/app/data/reports
MODELS_INPUT_PATH=/models
ML_RESULTS_PATH=/results

# ── Scope ─────────────────────────────────────────────────
SCOPE_FILE_PATH=/app/config/scope.yaml

# ── Cloud credentials (optional persistent paths) ─────────
# CLOUD_SECRETS_PATH=/app/secrets
# AWS_CREDS_FILE=/app/secrets/aws_creds.yaml
# AZURE_CREDS_FILE=/app/secrets/azure_creds.yaml
# GCP_CREDS_FILE=/app/secrets/gcp_creds.yaml