# =============================================================================
# Optimus Prime v2.0 — Environment Configuration
# =============================================================================

# --- LLM Configuration ---
CLAUDE_API_KEY=sk-your-claude-api-key-here
CLAUDE_MODEL=claude-sonnet-4-6
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b

# Thinking mode MUST be disabled for tool-call tasks (see Issue #14):
OLLAMA_THINKING_ENABLED=false

# --- Authentication ---
# Single user mode (default)
AUTH_TOKEN=your-static-bearer-token-here

# Collaboration mode (optional)
COLLAB_JWT_SECRET=your-jwt-secret-here-min-32-chars
COLLAB_USERS=lead:password_hash_here,analyst:password_hash_here

# --- Kali SSH ---
KALI_HOST=kali
KALI_PORT=22
KALI_USER=root
KALI_PASSWORD=optimus

# --- Token Budget ---
TOKEN_BUDGET_PER_SESSION=200000
TOKEN_BUDGET_WARNING_PCT=80
RESEARCH_DAEMON_TOKEN_BUDGET=50000

# --- Research Daemon ---
RESEARCH_DAEMON_SCHEDULE=0 2 * * *
RESEARCH_NVD_API_KEY=
RESEARCH_SHODAN_API_KEY=

# --- Tor Proxy ---
TOR_SOCKS5_HOST=tor
TOR_SOCKS5_PORT=9050

# --- Sandbox ---
DVWA_HOST=sandbox
DVWA_PORT=80
